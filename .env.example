# Frontend Environment Variables

# Whether to disable the Google Gemini model option and show a "Coming Soon!" tooltip
VITE_DISABLE_GEMINI=true

# The base URL of the Orchestrator API backend.
# Leave empty to use local Vite dev server proxy (forwarding /api requests to http://localhost:3000)
# In production, set to https://armour-orchestrator.vercel.app
VITE_API_URL=http://localhost:3000
